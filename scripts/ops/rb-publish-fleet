#!/usr/bin/env python3
"""Deprecated RepoBrief fleet-publisher entry point.

Use ``repoground-publish-fleet``. This delegate remains during RepoGround 3.x
so existing timers and operator commands execute the same implementation.
"""

from __future__ import annotations

import runpy
import sys
from pathlib import Path


def main() -> None:
    target = Path(__file__).with_name("repoground-publish-fleet")
    print(
        "rb-publish-fleet is deprecated; use repoground-publish-fleet",
        file=sys.stderr,
    )
    runpy.run_path(str(target), run_name="__main__")


if __name__ == "__main__":
    main()
