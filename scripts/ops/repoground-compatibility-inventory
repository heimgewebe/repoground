#!/usr/bin/env python3
"""Emit a redacted, read-only RepoGround compatibility inventory."""
from __future__ import annotations

import argparse
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[2]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from merger.repoground.core.compatibility_inventory import (  # noqa: E402
    build_inventory,
    dumps_inventory,
)


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description="Report bounded legacy process, config and service usage without raw secrets."
    )
    parser.add_argument(
        "--config",
        action="append",
        default=[],
        help="Config file to scan by hash and compatibility category; repeatable.",
    )
    parser.add_argument("--proc-root", default="/proc", help=argparse.SUPPRESS)
    parser.add_argument(
        "--no-services",
        action="store_true",
        help="Skip systemd user-unit observation.",
    )
    parser.add_argument(
        "--fail-on-legacy",
        action="store_true",
        help="Exit 1 when any process or config compatibility surface is observed.",
    )
    return parser


def main(argv: list[str] | None = None) -> int:
    args = build_parser().parse_args(argv)
    inventory = build_inventory(
        config_paths=args.config,
        proc_root=args.proc_root,
        include_services=not args.no_services,
    )
    sys.stdout.write(dumps_inventory(inventory))
    return 1 if args.fail_on_legacy and inventory["matched_surfaces"] else 0


if __name__ == "__main__":
    raise SystemExit(main())
