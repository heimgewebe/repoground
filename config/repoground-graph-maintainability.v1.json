{
  "kind": "repoground.graph_maintainability_policy",
  "version": "1.0",
  "graph": {
    "parse_success_rate_min": 0.99,
    "file_unknown_layer_share_max": 0.01,
    "product_unknown_layer_share_max": 0.01,
    "external_to_file_ratio_max": 0.6,
    "edges_per_parsed_file_max": 12.0
  },
  "entrypoints": {
    "required_projections": [
      "product",
      "test",
      "fixture",
      "script"
    ]
  },
  "complexity": {
    "baseline_path": "config/repoground-c901-baseline.v1.json",
    "policy": "existing identities may disappear; new identities and higher complexity are blocked"
  },
  "does_not_establish": [
    "semantic correctness of inferred layers",
    "runtime call reachability",
    "complete entrypoint discovery",
    "overall maintainability"
  ]
}
