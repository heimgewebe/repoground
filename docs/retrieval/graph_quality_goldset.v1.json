{
  "kind": "lenskit.graph_quality_goldset",
  "version": "1.1",
  "fixture_root": "merger/lenskit/tests/fixtures/graph_quality_goldset",
  "local_resolution_cases": [
    {
      "id": "absolute-from-cli",
      "source": "cli/main.py",
      "target": "core/service.py",
      "import_form": "from core.service import run"
    },
    {
      "id": "relative-from-core",
      "source": "core/service.py",
      "target": "core/utils.py",
      "import_form": "from .utils import helper"
    },
    {
      "id": "absolute-from-test",
      "source": "tests/service_case.py",
      "target": "core/service.py",
      "import_form": "from core.service import run"
    },
    {
      "id": "absolute-from-worker",
      "source": "scripts/worker.py",
      "target": "core/service.py",
      "import_form": "from core.service import run"
    },
    {
      "id": "package-init-import",
      "source": "package_case/consumer.py",
      "target": "package_case/pkg/__init__.py",
      "import_form": "import package_case.pkg"
    },
    {
      "id": "src-layout-import-root-gap",
      "source": "src_layout/consumer.py",
      "target": "src_layout/src/acme/service.py",
      "import_form": "from acme.service import run"
    },
    {
      "id": "namespace-import-root-gap",
      "source": "namespace_case/consumer.py",
      "target": "namespace_case/acme/alpha.py",
      "import_form": "from acme.alpha import run"
    }
  ],
  "external_preservation_cases": [
    {
      "id": "requests-remains-external",
      "source": "cli/main.py",
      "module": "requests"
    },
    {
      "id": "json-remains-external",
      "source": "core/service.py",
      "module": "json"
    },
    {
      "id": "ambiguous-search-roots-remain-external",
      "source": "collision_case/consumer.py",
      "module": "mod",
      "import_form": "import mod",
      "forbidden_targets": [
        "duplicate_case/mod.py",
        "package_case/mod.py"
      ]
    }
  ],
  "layer_cases": [
    {
      "path": "cli/main.py",
      "expected": "cli"
    },
    {
      "path": "core/service.py",
      "expected": "core"
    },
    {
      "path": "core/utils.py",
      "expected": "core"
    },
    {
      "path": "tests/service_case.py",
      "expected": "test"
    },
    {
      "path": "scripts/worker.py",
      "expected": "infra"
    },
    {
      "path": "misc/helpers.py",
      "expected": "unknown"
    },
    {
      "path": "tests/core/overlap_case.py",
      "expected": "test"
    },
    {
      "path": "tools/core/worker.py",
      "expected": "core"
    }
  ],
  "parse_failure_cases": [
    {
      "id": "invalid-syntax-is-skipped",
      "path": "invalid_case/broken.py"
    }
  ],
  "does_not_establish": [
    "runtime import behavior",
