{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://lenskit.merger/schemas/retrieval-eval.v1.json",
  "title": "Lenskit Retrieval Evaluation Report",
  "description": "Output schema for 'lenskit eval --emit json', containing metrics and query details.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "authority": {
      "type": "string",
      "const": "diagnostic_signal",
      "description": "Optional, additive top-level self-declaration of this report's authority class (C2.1). When present it MUST be the diagnostic_signal constant. Independent of and consistent with the existing nested miss_taxonomy.authority; it is not a truth verdict and does not gate anything."
    },
    "risk_class": {
      "type": "string",
      "const": "diagnostic",
      "description": "Optional, additive top-level self-declaration of this report's risk class (C2.1). When present it MUST be the diagnostic constant. Independent of and consistent with the existing nested miss_taxonomy.risk_class."
    },
    "allowed_inferences": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Optional C2.3 inference-boundary notes describing permitted uses of this diagnostic artifact. Free strings for now: this is contract-only preparation, not a closed policy vocabulary, truth verdict, lint, or export gate."
    },
    "forbidden_inferences": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Optional C2.3 inference-boundary notes that machine-readably mirror existing boundary disclaimers (e.g. claim_boundaries.does_not_prove). Free strings for now: this is contract-only preparation, not claim evaluation, lint, or export gate."
    },
    "metrics": {
      "type": "object",
      "description": "Aggregate metrics for the evaluation run.",
      "additionalProperties": false,
      "properties": {
        "MRR": {
          "type": "number",
          "description": "Mean Reciprocal Rank for the overall evaluation run. When running in compare mode with semantic reranking, this equals the semantic_MRR.",
          "minimum": 0,
          "maximum": 1
        },
        "baseline_MRR": {
          "type": "number",
          "description": "Baseline Mean Reciprocal Rank without semantic reranking.",
          "minimum": 0,
          "maximum": 1
        },
        "baseline_hits": {
          "type": "integer",
          "description": "Number of baseline hits without semantic reranking.",
          "minimum": 0
        },
        "semantic_MRR": {
          "type": "number",
          "description": "Semantic Mean Reciprocal Rank.",
          "minimum": 0,
          "maximum": 1
        },
        "semantic_hits": {
          "type": "integer",
          "description": "Number of semantic hits.",
          "minimum": 0
        },
        "delta_recall": {
          "type": "number",
          "description": "Difference in recall (semantic minus baseline)."
        },
        "delta_mrr": {
          "type": "number",
          "description": "Difference in MRR (semantic minus baseline)."
        },
        "total_queries": {
          "type": "integer",
          "description": "Total number of queries in the evaluation set.",
          "minimum": 0
        },
        "hits": {
          "type": "integer",
          "description": "Number of queries where at least one expected path was found in the top-k results.",
          "minimum": 0
        },
        "question_hits": {
          "type": "integer",
          "description": "Number of benchmark questions with at least one expected target in top-k.",
          "minimum": 0
        },
        "question_misses": {
          "type": "integer",
          "description": "Number of benchmark questions without an expected target in top-k.",
          "minimum": 0
        },
        "expected_target_total": {
          "type": "integer",
          "description": "Total independently expected paths or symbols across benchmark questions.",
          "minimum": 0
        },
        "expected_target_hits": {
          "type": "integer",
          "description": "Expected targets independently found in top-k.",
          "minimum": 0
        },
        "expected_target_misses": {
          "type": "integer",
          "description": "Expected targets independently missing from top-k.",
          "minimum": 0
        },
        "stale_flag": {
          "type": "boolean",
          "description": "True if the index was stale during evaluation."
        },
        "zero_hit_ratio": {
          "type": "number",
          "description": "Ratio of queries that returned 0 total hits (0.0 to 1.0).",
          "minimum": 0,
          "maximum": 1
        },
        "categories": {
          "type": "object",
          "description": "Metrics broken down by category.",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "total_queries": {
                "type": "integer",
                "minimum": 0
              },
              "hits": {
                "type": "integer",
                "minimum": 0
              },
              "MRR": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "base_hits": {
                "type": "integer",
                "minimum": 0
              },
              "base_mrr_sum": {
                "type": "number",
                "minimum": 0
              },
              "sem_hits": {
                "type": "integer",
                "minimum": 0
              },
              "sem_mrr_sum": {
                "type": "number",
                "minimum": 0
              },
              "semantic_MRR": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "expected_target_total": {
                "type": "integer",
                "minimum": 0
              },
              "expected_target_hits": {
                "type": "integer",
                "minimum": 0
              },
              "expected_target_misses": {
                "type": "integer",
                "minimum": 0
              }
            },
            "patternProperties": {
              "^recall@\\d+$": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              },
              "^semantic_recall@\\d+$": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              },
              "^question_recall@\\d+$": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              },
              "^expected_target_recall@\\d+$": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              }
            },
            "required": ["total_queries"]
          }
        }
      },
      "patternProperties": {
        "^recall@\\d+$": {
          "type": "number",
          "description": "Recall at K, strictly represented as a percentage (0.0 to 100.0). Note: accept_criteria in queries JSON uses a ratio (0.0 to 1.0). When running in compare mode with semantic reranking, this equals the semantic_recall@K.",
          "minimum": 0,
          "maximum": 100
        },
        "^baseline_recall@\\d+$": {
          "type": "number",
          "description": "Baseline Recall at K without semantic reranking.",
          "minimum": 0,
          "maximum": 100
        },
        "^semantic_recall@\\d+$": {
          "type": "number",
          "description": "Semantic Recall at K.",
          "minimum": 0,
          "maximum": 100
        },
        "^question_recall@\\d+$": {
          "type": "number",
          "description": "Question-level recall percentage: a question is a hit when any expected target is retrieved.",
          "minimum": 0,
          "maximum": 100
        },
        "^expected_target_recall@\\d+$": {
          "type": "number",
          "description": "Expected-target recall percentage: every expected path or symbol is counted independently.",
          "minimum": 0,
          "maximum": 100
        }
      },
      "required": [
        "total_queries",
        "hits",
        "stale_flag"
      ]
    },
    "details": {
      "type": "array",
      "description": "Detailed results for each query.",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "query": {
            "type": "string",
            "description": "The query text."
          },
          "category": {
            "type": ["string", "null"],
            "description": "The category of the query."
          },
          "filters": {
            "type": "object",
            "description": "Filters applied to the query.",
            "additionalProperties": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "expected": {
            "type": "array",
            "description": "List of expected path substrings.",
            "items": {
              "type": "string"
            }
          },
          "is_relevant": {
            "type": "boolean",
            "description": "True if an expected path was found in the top results."
          },
          "hit_path": {
            "type": [
              "string",
              "null"
            ],
            "description": "The first matching path found, if any."
          },
          "found_count": {
            "type": "integer",
            "description": "Total number of results returned by the index for this query.",
            "minimum": 0
          },
          "top_results": {
            "type": "array",
            "description": "List of paths returned in the top-k results.",
            "items": {
              "type": "string"
            }
          },
          "error": {
            "type": [
              "string",
              "null"
            ],
            "description": "Error message if the query failed."
          },
          "why": {
            "type": "object",
            "description": "Machine-readable explainability block for the matched hit.",
            "additionalProperties": false,
            "required": [
              "matched_terms",
              "filter_pass",
              "rank_features"
            ],
            "properties": {
              "matched_terms": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "The input or translated terms used for execution."
              },
              "filter_pass": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "List of global filter keys applied to the query."
              },
              "rank_features": {
                "type": "object",
                "additionalProperties": true,
                "description": "Ranking features like bm25."
              },
              "diagnostics": {
                "type": "object",
                "additionalProperties": true,
                "description": "Optional diagnostics information."
              }
            }
          }
        },
        "required": [
          "query",
          "is_relevant",
          "found_count",
          "expected"
        ]
      }
    },
    "measurement_conditions": {
      "type": "object",
      "description": "Optional machine-readable conditions that changed evaluation scope or ranking.",
      "additionalProperties": false,
      "properties": {
        "excluded_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "match": {
          "type": "string",
          "const": "exact_repository_path"
        },
        "application": {
          "type": "string",
          "enum": [
            "before_order_by_and_limit",
            "before_order_by_and_limit_per_lane"
          ]
        },
        "ranking_algorithm_changed": {
          "type": "boolean"
        },
        "review_intent": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "enabled",
            "requested",
            "plan_version",
            "fusion",
            "default_promoted",
            "executed_queries",
            "fallback_queries",
            "error_queries",
            "fallback_mode",
            "ranking_algorithm_changed"
          ],
          "properties": {
            "enabled": {
              "type": "boolean",
              "const": true
            },
            "requested": {
              "type": "boolean",
              "const": true
            },
            "plan_version": {
              "type": "string",
              "const": "review_intent.v1"
            },
            "fusion": {
              "type": "string",
              "const": "round_robin_unique_path"
            },
            "default_promoted": {
              "type": "boolean",
              "const": false
            },
            "executed_queries": {
              "type": "integer",
              "minimum": 0
            },
            "fallback_queries": {
              "type": "integer",
              "minimum": 0
            },
            "error_queries": {
              "type": "integer",
              "minimum": 0
            },
            "fallback_mode": {
              "type": "string",
              "const": "legacy"
            },
            "ranking_algorithm_changed": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "claim_boundaries": {
      "type": "object",
      "description": "Machine-readable epistemic boundaries of the evaluation output.",
      "additionalProperties": false,
      "required": [
        "proves",
        "does_not_prove",
        "evidence_basis",
        "requires_live_check"
      ],
      "properties": {
        "proves": {
          "type": "array",
          "items": {"type": "string"},
          "minItems": 1
        },
        "does_not_prove": {
          "type": "array",
          "items": {"type": "string"},
          "minItems": 1
        },
        "evidence_basis": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "eval_queries",
              "expected_targets",
              "query_results",
              "index",
              "retrieval_metrics",
              "graph_index",
              "path_exclusions"
            ]
          },
          "minItems": 1
        },
        "requires_live_check": {
          "type": "boolean"
        }
      }
    },
    "miss_taxonomy": {
      "type": "object",
      "description": "Diagnostic classification of retrieval misses. Conservative, mechanical categorization of why expected targets were not retrieved. In compare mode this classifies the top-level active eval view in details[] (baseline sub-blocks are not separately classified in v1). Does NOT prove repository absence.",
      "additionalProperties": false,
      "properties": {
        "version": {
          "type": "string",
          "description": "Version of the miss taxonomy schema.",
          "const": "1.0"
        },
        "authority": {
          "type": "string",
          "description": "Authority level of this diagnostic.",
          "const": "diagnostic_signal"
        },
        "risk_class": {
          "type": "string",
          "description": "Risk classification.",
          "const": "diagnostic"
        },
        "classification_basis": {
          "type": "array",
          "description": "List of information sources used for miss classification.",
          "items": {
            "type": "string",
            "enum": [
              "retrieval_eval_expectations",
              "returned_hit_paths",
              "chunk_index_paths",
              "query_metadata",
              "filter_configuration"
            ]
          },
          "minItems": 1
        },
        "does_not_prove": {
          "type": "array",
          "description": "Explicit statements of what this taxonomy does NOT prove.",
          "items": {"type": "string"},
          "minItems": 1,
          "allOf": [
            {
              "contains": {
                "const": "absence_of_retrieval_hit_does_not_prove_absence_in_repository"
              }
            },
            {
              "contains": {
                "const": "miss_type_does_not_prove_claim_truth_or_falsehood"
              }
            },
            {
              "contains": {
                "const": "ranking_position_does_not_prove_semantic_importance"
              }
            },
            {
              "contains": {
                "const": "retrieval_eval_does_not_prove_retrieval_completeness"
              }
            },
            {
              "contains": {
                "const": "taxonomy_is_diagnostic_not_authoritative"
              }
            }
          ]
        },
        "aggregate": {
          "type": "object",
          "description": "Aggregate statistics for missed queries.",
          "additionalProperties": false,
          "properties": {
            "total_cases_classified": {
              "type": "integer",
              "description": "Total number of queries classified.",
              "minimum": 0
            },
            "total_misses": {
              "type": "integer",
              "description": "Total number of missed queries.",
              "minimum": 0
            },
            "by_type": {
              "type": "object",
              "description": "Count of each miss type.",
              "additionalProperties": false,
              "properties": {
                "zero_results": {"type": "integer", "minimum": 0},
                "expected_not_in_top_k": {"type": "integer", "minimum": 0},
                "expected_rank_below_k": {"type": "integer", "minimum": 0},
                "expected_path_not_indexed": {"type": "integer", "minimum": 0},
                "expected_symbol_not_indexed": {"type": "integer", "minimum": 0},
                "path_or_symbol_metadata_missing": {"type": "integer", "minimum": 0},
                "possible_query_vocabulary_gap": {"type": "integer", "minimum": 0},
                "possible_filter_scope_gap": {"type": "integer", "minimum": 0},
                "noise_or_fixture_hit": {"type": "integer", "minimum": 0},
                "stale_eval_input": {"type": "integer", "minimum": 0},
                "query_execution_error": {"type": "integer", "minimum": 0},
                "unknown": {"type": "integer", "minimum": 0}
              },
              "required": [
                "zero_results",
                "expected_not_in_top_k",
                "expected_rank_below_k",
                "expected_path_not_indexed",
                "expected_symbol_not_indexed",
                "path_or_symbol_metadata_missing",
                "possible_query_vocabulary_gap",
                "possible_filter_scope_gap",
                "noise_or_fixture_hit",
                "stale_eval_input",
                "query_execution_error",
                "unknown"
              ]
            }
          },
          "required": ["total_cases_classified", "total_misses", "by_type"]
        },
        "cases": {
          "type": "array",
          "description": "Detailed miss classification per query case.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "query_index": {
                "type": "integer",
                "description": "Index of the query in the details array."
              },
              "query": {
                "type": "string",
                "description": "Query text reference."
              },
              "expected": {
                "type": "array",
                "description": "Expected target patterns.",
                "items": {"type": "string"}
              },
              "is_relevant": {
                "type": "boolean",
                "description": "Whether this query had a hit (not a miss)."
              },
              "observed_top_k_count": {
                "type": "integer",
                "description": "Number of results returned.",
                "minimum": 0
              },
              "miss_types": {
                "type": "array",
                "description": "Primary and secondary miss classifications.",
                "items": {
                  "type": "string",
                  "enum": [
                    "zero_results",
                    "expected_not_in_top_k",
                    "expected_rank_below_k",
                    "expected_path_not_indexed",
                    "expected_symbol_not_indexed",
                    "path_or_symbol_metadata_missing",
                    "possible_query_vocabulary_gap",
                    "possible_filter_scope_gap",
                    "noise_or_fixture_hit",
                    "stale_eval_input",
                    "query_execution_error",
                    "unknown"
                  ]
                },
                "minItems": 1
              },
              "primary_miss_type": {
                "type": "string",
                "description": "Most specific/mechanically-backed miss type.",
                "enum": [
                  "zero_results",
                  "expected_not_in_top_k",
                  "expected_rank_below_k",
                  "expected_path_not_indexed",
                  "expected_symbol_not_indexed",
                  "path_or_symbol_metadata_missing",
                  "possible_query_vocabulary_gap",
                  "possible_filter_scope_gap",
                  "noise_or_fixture_hit",
                  "stale_eval_input",
                  "query_execution_error",
                  "unknown"
                ]
              },
              "classification_basis": {
                "type": "array",
                "description": "Which sources justified this classification.",
                "items": {"type": "string"}
              },
              "notes": {
                "type": "array",
                "description": "Optional human-readable notes on the classification.",
                "items": {"type": "string"}
              }
            },
            "required": ["query_index", "is_relevant", "miss_types", "primary_miss_type", "classification_basis"]
          }
        }
      },
      "required": ["version", "authority", "risk_class", "classification_basis", "does_not_prove", "aggregate"]
    },
    "benchmark": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "scope",
        "canonical",
        "query_source",
        "query_source_sha256",
        "validation_status",
        "evaluation_mode",
        "default_promotion_allowed",
        "promotion_status",
        "promotion_block_reasons",
        "does_not_establish"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["repository_review_goldset", "generic_example"]
        },
        "scope": {
          "type": "string",
          "enum": ["repository_specific", "generic_diagnostic_sample"]
        },
        "canonical": {"type": "boolean"},
        "query_source": {"type": "string", "minLength": 1},
        "query_source_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "contract": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "version"],
          "properties": {
            "id": {"type": "string", "const": "review-retrieval-goldset"},
            "version": {"type": "string", "const": "v1"}
          }
        },
        "validation_status": {
          "type": "string",
          "enum": ["pass", "not_applicable"]
        },
        "evaluation_mode": {"type": "string", "const": "default_lexical"},
        "default_promotion_allowed": {"type": "boolean", "const": false},
        "promotion_status": {"type": "string", "const": "blocked"},
        "promotion_block_reasons": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "does_not_establish": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {"kind": {"const": "repository_review_goldset"}}
          },
          "then": {
            "required": ["contract"],
            "properties": {
              "scope": {"const": "repository_specific"},
              "canonical": {"const": true},
              "validation_status": {"const": "pass"}
            }
          }
        },
        {
          "if": {
            "properties": {"kind": {"const": "generic_example"}}
          },
          "then": {
            "not": {"required": ["contract"]},
            "properties": {
              "scope": {"const": "generic_diagnostic_sample"},
              "canonical": {"const": false},
              "validation_status": {"const": "not_applicable"}
            }
          }
        }
      ]
    },
    "review_measurement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "metrics",
        "categories",
        "acceptance",
        "miss_taxonomy_summary",
        "miss_diagnostics",
        "does_not_establish"
      ],
      "properties": {
        "version": {"type": "string", "const": "1.1"},
        "metrics": {"type": "object", "additionalProperties": true},
        "categories": {
          "type": "object",
          "additionalProperties": {"type": "object"}
        },
        "acceptance": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "criterion",
            "evaluated_queries",
            "passed_queries",
            "failed_queries",
            "status",
            "does_not_allow_default_promotion"
          ],
          "properties": {
            "criterion": {"type": "string", "pattern": "^recall_at_\\d+$"},
            "evaluated_queries": {"type": "integer", "minimum": 0},
            "passed_queries": {"type": "integer", "minimum": 0},
            "failed_queries": {"type": "integer", "minimum": 0},
            "status": {
              "type": "string",
              "enum": ["pass", "fail", "not_evaluated"]
            },
            "does_not_allow_default_promotion": {
              "type": "boolean",
              "const": true
            }
          }
        },
        "miss_taxonomy_summary": {
          "type": "object",
          "additionalProperties": {"type": "integer", "minimum": 0}
        },
        "miss_diagnostics": {
          "type": "array",
          "items": {"type": "object"}
        },
        "does_not_establish": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "required": ["benchmark"],
        "properties": {
          "benchmark": {
            "properties": {"kind": {"const": "repository_review_goldset"}}
          }
        }
      },
      "then": {"required": ["review_measurement"]}
    },
    {
      "if": {
        "required": ["benchmark"],
        "properties": {
          "benchmark": {
            "properties": {"kind": {"const": "generic_example"}}
          }
        }
      },
      "then": {"not": {"required": ["review_measurement"]}}
    }
  ],
  "required": [
    "metrics",
    "details",
    "claim_boundaries"
  ]
}
