{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "lenskit/schema/agent-benchmark-taskset.v1.schema.json",
  "title": "RepoBrief Agent Benchmark Taskset v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "version",
    "id",
    "measurement_scope",
    "repositories",
    "tool_policy",
    "budgets",
    "thresholds",
    "cases",
    "default_promoted",
    "does_not_establish"
  ],
  "properties": {
    "kind": {"const": "repobrief.agent_benchmark_taskset"},
    "version": {"const": "1.0"},
    "id": {"type": "string", "minLength": 1},
    "measurement_scope": {"const": "frozen_paired_agent_ab"},
    "repositories": {
      "type": "array",
      "minItems": 3,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "repository", "commit", "snapshot_profile"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]+$"},
          "repository": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},
          "commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
          "snapshot_profile": {"type": "string", "minLength": 1}
        }
      }
    },
    "tool_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["baseline", "treatment"],
      "properties": {
        "baseline": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]+$"}
        },
        "treatment": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]+$"}
        }
      }
    },
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wall_seconds",
        "input_tokens",
        "output_tokens",
        "max_tool_calls",
        "max_tool_input_bytes",
        "max_tool_output_bytes"
      ],
      "properties": {
        "wall_seconds": {"type": "integer", "minimum": 1, "maximum": 3600},
        "input_tokens": {"type": "integer", "minimum": 1},
        "output_tokens": {"type": "integer", "minimum": 1},
        "max_tool_calls": {"type": "integer", "minimum": 1, "maximum": 1000},
        "max_tool_input_bytes": {"type": "integer", "minimum": 1},
        "max_tool_output_bytes": {"type": "integer", "minimum": 1}
      }
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minimum_efficiency_improvement",
        "minimum_success_rate_gain",
        "maximum_class_success_regression",
        "maximum_false_confidence_increase"
      ],
      "properties": {
        "minimum_efficiency_improvement": {"type": "number", "minimum": 0, "maximum": 1},
        "minimum_success_rate_gain": {"type": "number", "minimum": 0, "maximum": 1},
        "maximum_class_success_regression": {"type": "number", "minimum": 0, "maximum": 1},
        "maximum_false_confidence_increase": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "cases": {
      "type": "array",
      "minItems": 24,
      "maxItems": 24,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "category",
          "repository_id",
          "prompt",
          "setup",
          "expectations",
          "tags"
        ],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]+$"},
          "category": {"enum": ["navigation", "structural", "grounding_freshness"]},
          "repository_id": {"type": "string", "minLength": 1},
          "prompt": {"type": "string", "minLength": 1, "maxLength": 4000},
          "setup": {
            "type": "object",
            "additionalProperties": false,
            "required": ["working_tree"],
            "properties": {
              "working_tree": {
                "enum": ["clean", "dirty", "head_mismatch", "no_repo_root", "missing_provenance", "invalid_citation"]
              },
              "fixture": {"type": ["string", "null"], "maxLength": 256}
            }
          },
          "expectations": {
            "type": "object",
            "additionalProperties": false,
            "required": ["baseline", "treatment"],
            "properties": {
              "baseline": {"$ref": "#/definitions/expectation"},
              "treatment": {"$ref": "#/definitions/expectation"}
            }
          },
          "tags": {
            "type": "array",
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "default_promoted": {"const": false},
    "does_not_establish": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    }
  },
  "definitions": {
    "citation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "start_line", "end_line"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "start_line": {"type": "integer", "minimum": 1},
        "end_line": {"type": "integer", "minimum": 1}
      }
    },
    "expectation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "outcome",
        "required_paths",
        "allowed_paths",
        "forbidden_paths",
        "required_symbols",
        "required_citations",
        "required_claims",
        "forbidden_claims"
      ],
      "properties": {
        "outcome": {"enum": ["answer", "abstain", "stale", "not_comparable", "invalid_evidence"]},
        "required_paths": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "allowed_paths": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "forbidden_paths": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "required_symbols": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "required_citations": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/definitions/citation"}},
        "required_claims": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "forbidden_claims": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    }
  }
}
