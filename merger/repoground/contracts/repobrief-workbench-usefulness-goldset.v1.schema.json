{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://lenskit.merger/schemas/repobrief-workbench-usefulness-goldset.v1.json",
  "title": "RepoBrief Workbench usefulness goldset v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "version", "questions", "does_not_establish"],
  "properties": {
    "kind": {"const": "repobrief.workbench_usefulness_goldset"},
    "version": {"const": "1.0"},
    "questions": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "query", "expected_paths", "expected_symbols"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "query": {"type": "string", "minLength": 1},
          "symbol_query": {"type": "string", "minLength": 1},
          "symbol_kind": {"type": ["string", "null"], "enum": ["class", "function", "async_function", null]},
          "symbol_path_filter": {"type": ["string", "null"]},
          "expected_paths": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "expected_symbols": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "filters": {"type": "object"}
        }
      }
    },
    "does_not_establish": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  }
}
