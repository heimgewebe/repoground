{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "lenskit/schema/agent-benchmark-run-request.v1.schema.json",
  "title": "RepoBrief Agent Benchmark Run Request v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "version",
    "request_id",
    "pair_id",
    "case_id",
    "condition",
    "order",
    "repetition",
    "taskset_id",
    "taskset_sha256",
    "repository",
    "session_id",
    "workspace_id",
    "prompt",
    "allowed_tools",
    "budgets",
    "runner",
    "repobrief",
    "isolation",
    "does_not_establish"
  ],
  "properties": {
    "kind": {"const": "repobrief.agent_benchmark_run_request"},
    "version": {"const": "1.0"},
    "request_id": {"type": "string", "minLength": 1},
    "pair_id": {"type": "string", "minLength": 1},
    "case_id": {"type": "string", "minLength": 1},
    "condition": {"enum": ["baseline", "treatment"]},
    "order": {"type": "integer", "minimum": 1, "maximum": 2},
    "repetition": {"type": "integer", "minimum": 1},
    "taskset_id": {"type": "string", "minLength": 1},
    "taskset_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "repository", "commit"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "repository": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},
        "commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"}
      }
    },
    "session_id": {"type": "string", "minLength": 1},
    "workspace_id": {"type": "string", "minLength": 1},
    "prompt": {"type": "string", "minLength": 1, "maxLength": 4000},
    "allowed_tools": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]+$"}
    },
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wall_seconds",
        "input_tokens",
        "output_tokens",
        "max_tool_calls",
        "max_tool_input_bytes",
        "max_tool_output_bytes"
      ],
      "properties": {
        "wall_seconds": {"type": "integer", "minimum": 1, "maximum": 3600},
        "input_tokens": {"type": "integer", "minimum": 1},
        "output_tokens": {"type": "integer", "minimum": 1},
        "max_tool_calls": {"type": "integer", "minimum": 1},
        "max_tool_input_bytes": {"type": "integer", "minimum": 1},
        "max_tool_output_bytes": {"type": "integer", "minimum": 1}
      }
    },
    "runner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "model", "sampling"],
      "properties": {
        "provider": {"type": "string", "minLength": 1},
        "model": {"type": "string", "minLength": 1},
        "sampling": {"type": "object"},
        "execution_contract": {
          "type": "string",
          "enum": ["grabowski-claude-code-live-v1"]
        }
      }
    },
    "repobrief": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["manifest", "manifest_sha256", "mcp_command"],
      "properties": {
        "manifest": {"type": "string", "minLength": 1},
        "manifest_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "mcp_command": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "isolation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fresh_session", "fresh_workspace", "cross_condition_reuse_allowed"],
      "properties": {
        "fresh_session": {"const": true},
        "fresh_workspace": {"const": true},
        "cross_condition_reuse_allowed": {"const": false}
      }
    },
    "does_not_establish": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
