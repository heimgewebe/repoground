{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://lenskit.merger/schemas/audit-verification-record.v1.json",
  "title": "Lenskit Audit Verification Record",
  "description": "A neutral, revision-bound verifier decision. It is diagnostic and does not establish repository truth.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "authority",
    "risk_class",
    "finding_id",
    "reviewed_revision",
    "decision",
    "verifier_id",
    "note",
    "does_not_prove"
  ],
  "properties": {
    "version": {
      "const": "audit_verification_record.v1"
    },
    "authority": {
      "const": "diagnostic_signal"
    },
    "risk_class": {
      "const": "diagnostic"
    },
    "finding_id": {
      "type": "string",
      "pattern": "^af2_[a-f0-9]{16}$"
    },
    "reviewed_revision": {
      "type": "string",
      "pattern": "^[a-f0-9]{40}$"
    },
    "decision": {
      "type": "string",
      "enum": [
        "accepted",
        "rejected",
        "unresolved"
      ]
    },
    "verifier_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "note": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048
    },
    "does_not_prove": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "repository truth",
          "review completeness",
          "freshness beyond the recorded revision",
          "permission to create issues, patches, commits, pushes, or merges"
        ]
      },
      "allOf": [
        {
          "contains": {
            "const": "repository truth"
          }
        },
        {
          "contains": {
            "const": "review completeness"
          }
        },
        {
          "contains": {
            "const": "freshness beyond the recorded revision"
          }
        },
        {
          "contains": {
            "const": "permission to create issues, patches, commits, pushes, or merges"
          }
        }
      ]
    }
  }
}
