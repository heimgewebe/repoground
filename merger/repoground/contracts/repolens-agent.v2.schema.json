{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heimgewebe.local/contracts/repolens-agent.v2.schema.json",
  "title": "repolens-agent.v2",
  "type": "object",
  "required": ["reading_policy", "meta", "artifacts", "files"],
  "properties": {
    "reading_policy": {
      "type": "object",
      "description": "Declares the canonical source of truth and reading requirements.",
      "properties": {
        "canonical_content_artifact": { "type": "string" },
        "navigation_artifacts": { "type": "array", "items": { "type": "string" } },
        "do_not_assume_json_contains_full_content": { "type": "boolean" },
        "preferred_retrieval": { "type": "array", "items": { "type": "string" } },
        "canonical_source": { "type": "string", "enum": ["md"] },
        "md_required": { "type": "boolean" },
        "json_role": { "type": "string" },
        "md_contains_full_information": { "type": "boolean" },
        "lenses_applied": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "meta": {
      "type": "object",
      "required": ["contract", "contract_version", "generated_at", "profile"],
      "properties": {
        "contract": { "const": "repolens-agent" },
        "contract_version": { "const": "v2" },
        "generated_at": { "type": "string" },
        "profile": { "type": "string" },
        "output_mode": { "type": "string" },
        "include_hidden": { "type": "boolean" },
        "redact_secrets": { "type": "boolean" },
        "split_size_bytes": { "type": "integer" },
        "max_bytes": { "type": "integer" },
        "schema_ids": { "type": "array", "items": { "type": "string" } },
        "mode": {
          "type": "string",
          "enum": ["full", "plan-only", "code-only", "none"],
          "description": "Operational mode. 'none' disables all epistemic/interpretative layers."
        },
        "plan_only": { "type": "boolean" },
        "code_only": { "type": "boolean" },
        "max_file_bytes": { "type": "integer" },
        "meta_density": {
          "type": "string",
          "enum": ["min", "standard", "full"],
          "description": "Effektiver Drosselungs-Grad (berechnet)."
        },
        "requested_meta_density": {
          "type": "string",
          "enum": ["min", "standard", "full", "auto"],
          "description": "Urspr√ºnglich angeforderte Dichte (z.B. 'auto')."
        },
        "total_files": { "type": "integer" },
        "total_size_bytes": { "type": "integer" },
        "source_repos": { "type": "array", "items": { "type": "string" } },
        "filters": { "type": "object" }
      },
      "additionalProperties": true
    },
    "artifacts": {
      "type": "object",
      "required": ["index_json", "canonical_md", "md_parts"],
      "properties": {
        "index_json": { "type": ["string", "null"] },
        "canonical_md": { "type": ["string", "null"] },
        "md_parts": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "coverage": { "type": "object" },
    "scope": { "type": ["string", "object", "null"] },
    "delta": { "type": ["object", "null"] },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "path", "included", "inclusion_status"],
        "properties": {
          "id": { "type": "string" },
          "path": { "type": "string" },
          "repo": { "type": "string" },
          "size_bytes": { "type": "integer" },
          "is_text": { "type": "boolean" },
          "category": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "included": { "type": "boolean" },
          "inclusion_status": { "type": "string" },
          "content_ref": {
            "type": "object",
            "required": ["marker", "selector"],
            "properties": {
              "marker": { "type": "string" },
              "selector": {
                "type": "object",
                "required": ["kind", "tag", "attr", "value"],
                "properties": {
                  "kind": { "const": "html_comment_attr" },
                  "tag": { "const": "file" },
                  "attr": { "const": "id" },
                  "value": { "type": "string" }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          "md_ref": {
            "type": "object",
            "required": ["anchor", "fragment"],
            "properties": {
              "anchor": { "type": "string" },
              "fragment": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}