{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://lenskit.merger/schemas/repobrief-readonly-adapter-config.v1.json",
  "title": "RepoBrief read-only adapter config v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "version", "allowed_roots", "snapshots"],
  "properties": {
    "kind": {"const": "repobrief.readonly_adapter_config"},
    "version": {"const": "1.0"},
    "allowed_roots": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "snapshots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "manifest"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "manifest": {"type": "string", "minLength": 1}
        }
      }
    },
    "does_not_establish": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    }
  }
}
