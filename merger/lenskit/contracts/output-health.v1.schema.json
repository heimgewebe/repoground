{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://heimgewebe.local/schema/output-health.v1.schema.json",
  "title": "Output Health (output-health v1.0)",
  "description": "Machine-readable diagnostic health report for a Lenskit output bundle. Checks functional usability of the artifact chain without self-referential circularity.",
  "type": "object",
  "required": [
    "kind",
    "version",
    "run_id",
    "created_at",
    "stem",
    "checks",
    "warnings",
    "errors",
    "verdict"
  ],
  "properties": {
    "kind": {
      "type": "string",
      "const": "lenskit.output_health"
    },
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "description": "ISO 8601 UTC timestamp."
    },
    "stem": {
      "type": "string",
      "description": "Base stem of the output bundle (used to derive artifact file names)."
    },
    "checks": {
      "type": "object",
      "required": [
        "manifest_present",
        "canonical_md_required",
        "canonical_md_hash_ok",
        "chunk_index_required",
        "chunk_index_hash_ok",
        "chunk_count",
        "chunk_invalid_json_line_count",
        "chunk_missing_id_line_count",
        "chunk_empty_line_count",
        "sqlite_present",
        "sqlite_checks_required",
        "sqlite_row_count",
        "sqlite_row_count_matches_chunk_count",
        "sqlite_fts_row_count",
        "sqlite_fts_row_count_matches_chunk_count",
        "fts_content_non_empty",
        "fts_empty_row_count",
        "range_ref_resolution_ok",
        "redaction_status_explicit",
        "redact_secrets_enabled"
      ],
      "properties": {
        "manifest_present": {
          "type": "boolean",
          "description": "True if the primary artifact manifest (dump_index) is present. In this implementation this is intentionally decoupled from the final bundle manifest entry to avoid self-referential validation."
        },
        "canonical_md_required": {
          "type": "boolean",
          "description": "True when canonical_md is expected for this output mode or caller expectation."
        },
        "canonical_md_hash_ok": {
          "type": ["boolean", "null"],
          "description": "Null means not checked because canonical_md is not required in this output mode."
        },
        "chunk_index_required": {
          "type": "boolean",
          "description": "True when chunk_index_jsonl is expected for this output mode or caller expectation."
        },
        "chunk_index_hash_ok": {
          "type": ["boolean", "null"],
          "description": "Null means not checked because chunk_index_jsonl is not required in this output mode."
        },
        "chunk_count": {
          "type": "integer",
          "minimum": 0
        },
        "sqlite_present": {
          "type": "boolean"
        },
        "sqlite_checks_required": {
          "type": "boolean",
          "description": "True iff SQLite checks are required for this run. In the current implementation this is true when a sqlite artifact was materialized; this does not by itself prove sqlite generation was expected in every runtime environment."
        },
        "sqlite_row_count": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "sqlite_row_count_matches_chunk_count": {
          "type": ["boolean", "null"]
        },
        "sqlite_fts_row_count": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "sqlite_fts_row_count_matches_chunk_count": {
          "type": ["boolean", "null"]
        },
        "fts_content_non_empty": {
          "type": ["boolean", "null"]
        },
        "fts_empty_row_count": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "range_ref_resolution_ok": {
          "type": ["boolean", "null"],
          "description": "True=resolved ok, False=semantic failure (hard fail), null=check not executed (see range_ref_resolution_status)."
        },
        "range_ref_resolution_status": {
          "type": "string",
          "enum": ["ok", "fail", "environment_error", "no_range_ref", "unavailable", "skipped"],
          "description": "Fine-grained status for the range_ref check. 'environment_error' means jsonschema is unavailable — the check could not run, not that data is broken. 'fail' means a real semantic/structural error was detected."
        },
        "range_ref_resolution": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "required", "reason", "validation"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["ok", "fail", "environment_error", "no_range_ref", "unavailable", "skipped"]
            },
            "required": {
              "type": "boolean"
            },
            "reason": {
              "type": "string"
            },
            "validation": {
              "type": "object",
              "additionalProperties": false,
              "required": ["mode", "engine", "reason"],
              "properties": {
                "mode": {
                  "type": "string",
                  "enum": ["jsonschema", "minimal_fallback", "skipped_unavailable", "structural_precheck"]
                },
                "engine": {
                  "type": "string",
                  "enum": ["jsonschema", "range_resolver", "doc_freshness_minimal"]
                },
                "reason": {
                  "type": "string",
                  "enum": [
                    "available",
                    "dependency_unavailable",
                    "jsonschema_unavailable",
                    "schema_missing",
                    "check_not_applicable",
                    "unsupported_runtime",
                    "malformed_range_ref"
                  ]
                }
              }
            }
          }
        },
        "sample_query_content_hit": {
          "type": "object",
          "required": ["status", "required"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["pass", "warning", "fail", "skipped"]
            },
            "required": {
              "type": "boolean"
            },
            "reason": {
              "type": "string"
            }
          }
        },
        "agent_pack_present": {
          "type": "object",
          "required": ["status", "required"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["pass", "warning", "fail", "skipped"]
            },
            "required": {
              "type": "boolean"
            },
            "reason": {
              "type": "string"
            }
          }
        },
        "redaction_status_explicit": {
          "type": "boolean"
        },
        "redact_secrets_enabled": {
          "type": "boolean",
          "description": "Whether secrets redaction was enabled during health report generation."
        },
        "chunk_invalid_json_line_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of lines in chunk_index.jsonl that are invalid JSON or valid non-object JSON values."
        },
        "chunk_missing_id_line_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of JSON lines in chunk_index.jsonl that lack a valid chunk identifier (id or chunk_id field)."
        },
        "chunk_empty_line_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of empty lines in chunk_index.jsonl."
        }
      },
      "additionalProperties": true
    },
    "diagnostic_artifacts": {
      "type": "object",
      "description": "Optional: diagnostic artifacts from the bundle, e.g. retrieval_eval_json."
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "warn", "fail"]
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": false,
      "required": ["jsonschema"],
      "properties": {
        "jsonschema": {
          "type": "object",
          "additionalProperties": false,
          "required": ["available", "required_for", "effect"],
          "properties": {
            "available": { "type": "boolean" },
            "required_for": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["range_ref_schema"]
              },
              "minItems": 1,
              "maxItems": 1,
              "uniqueItems": true
            },
            "effect": {
              "type": "string",
              "enum": ["full_validation_available", "validation_degraded"]
            }
          },
          "allOf": [
            {
              "if": { "properties": { "available": { "const": true } }, "required": ["available"] },
              "then": { "properties": { "effect": { "const": "full_validation_available" } } }
            },
            {
              "if": { "properties": { "available": { "const": false } }, "required": ["available"] },
              "then": { "properties": { "effect": { "const": "validation_degraded" } } }
            }
          ]
        }
      }
    }
  },
  "additionalProperties": false
}
