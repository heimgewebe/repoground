{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://heimgewebe.local/contracts/repobrief-ask-context-pack.v1.schema.json",
  "title": "RepoBrief Ask Context Pack (repobrief-ask-context-pack v1.0)",
  "description": "Read-only context pack assembled for downstream answer generation from existing RepoBrief artifacts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "version",
    "request_id",
    "snapshot_ref",
    "freshness",
    "availability",
    "required_reading",
    "retrieval_hits",
    "resolved_ranges",
    "answer_scaffold",
    "forbidden_operations",
    "does_not_establish"
  ],
  "properties": {
    "kind": {
      "type": "string",
      "const": "repobrief.ask_context_pack"
    },
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "snapshot_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifest_path",
        "stem",
        "freshness_policy"
      ],
      "properties": {
        "stem": {
          "type": "string",
          "minLength": 1
        },
        "manifest_path": {
          "type": "string",
          "minLength": 1
        },
        "manifest_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "git_commit": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "freshness_policy": {
          "type": "string",
          "enum": [
            "use_existing_only",
            "require_fresh_or_fail",
            "allow_stale_with_caveat",
            "unknown_ok_with_caveat"
          ]
        },
        "freshness_status": {
          "type": "string",
          "enum": [
            "fresh",
            "stale",
            "unknown",
            "not_comparable",
            "not_applicable"
          ]
        }
      }
    },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "caveats"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "fresh",
            "stale",
            "unknown",
            "not_comparable",
            "not_applicable"
          ]
        },
        "caveats": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "detail"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "stale_snapshot",
                  "unknown_freshness",
                  "live_state_not_checked",
                  "missing_artifact",
                  "degraded_validation",
                  "other"
                ]
              },
              "detail": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "availability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "caveats"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "available",
            "partial",
            "missing",
            "unknown"
          ]
        },
        "caveats": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "detail"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "stale_snapshot",
                  "unknown_freshness",
                  "live_state_not_checked",
                  "missing_artifact",
                  "degraded_validation",
                  "other"
                ]
              },
              "detail": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "required_reading": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_profile",
        "required",
        "recommended",
        "missing_required",
        "missing_recommended",
        "status"
      ],
      "properties": {
        "task_profile": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommended": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missing_required": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missing_recommended": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "status": {
          "type": "string",
          "enum": [
            "pass",
            "warn",
            "fail",
            "not_applicable"
          ]
        }
      }
    },
    "retrieval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_query",
        "strategy",
        "match_count"
      ],
      "properties": {
        "raw_query": {
          "type": "string"
        },
        "fts_query": {
          "type": ["string", "null"]
        },
        "strategy": {
          "type": "string",
          "enum": [
            "exact_and",
            "or_relaxed",
            "none"
          ]
        },
        "match_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "retrieval_hits": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_role",
          "ref",
          "score"
        ],
        "properties": {
          "artifact_role": {
            "type": "string",
            "minLength": 1
          },
          "ref": {
            "type": "string",
            "minLength": 1
          },
          "score": {
            "type": "number"
          },
          "citation_id": {
            "type": "string",
            "pattern": "^cit_[a-f0-9]{16}$"
          },
          "purpose": {
            "type": "string"
          }
        }
      }
    },
    "resolved_ranges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_role",
          "status",
          "range_ref"
        ],
        "properties": {
          "artifact_role": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "resolved",
              "missing",
              "drifted",
              "invalid",
              "degraded",
              "not_applicable"
            ]
          },
          "range_ref": {
            "type": "object"
          },
          "text_excerpt": {
            "type": "string"
          },
          "content_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "source_path": {
            "type": "string",
            "minLength": 1
          },
          "source_line_range": {
            "type": "object"
          },
          "citation_id": {
            "type": "string",
            "pattern": "^cit_[a-f0-9]{16}$"
          }
        }
      }
    },
    "answer_scaffold": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "citation_obligations",
        "caveats_to_surface",
        "non_claims_to_surface"
      ],
      "properties": {
        "citation_obligations": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "caveats_to_surface": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "detail"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "stale_snapshot",
                  "unknown_freshness",
                  "live_state_not_checked",
                  "missing_artifact",
                  "degraded_validation",
                  "other"
                ]
              },
              "detail": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "non_claims_to_surface": {
          "type": "array",
          "minItems": 11,
          "maxItems": 11,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "actual_reading_proven",
              "answer_correct",
              "repo_understood",
              "all_relevant_context_used",
              "claims_true",
              "test_sufficiency",
              "regression_absence",
              "runtime_behavior",
              "forensic_ready",
              "merge_readiness",
              "security_correctness"
            ]
          },
          "allOf": [
            {
              "contains": {
                "const": "actual_reading_proven"
              }
            },
            {
              "contains": {
                "const": "answer_correct"
              }
            },
            {
              "contains": {
                "const": "repo_understood"
              }
            },
            {
              "contains": {
                "const": "all_relevant_context_used"
              }
            },
            {
              "contains": {
                "const": "claims_true"
              }
            },
            {
              "contains": {
                "const": "test_sufficiency"
              }
            },
            {
              "contains": {
                "const": "regression_absence"
              }
            },
            {
              "contains": {
                "const": "runtime_behavior"
              }
            },
            {
              "contains": {
                "const": "forensic_ready"
              }
            },
            {
              "contains": {
                "const": "merge_readiness"
              }
            },
            {
              "contains": {
                "const": "security_correctness"
              }
            }
          ],
          "description": "Non-claims downstream agents must keep visible."
        }
      }
    },
    "forbidden_operations": {
      "type": "array",
      "minItems": 7,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "implicit_refresh",
          "git_mutation",
          "snapshot_creation_on_read",
          "patch_application",
          "pull_request_mutation",
          "shell_execution",
          "merge_authorization"
        ]
      },
      "allOf": [
        {
          "contains": {
            "const": "implicit_refresh"
          }
        },
        {
          "contains": {
            "const": "git_mutation"
          }
        },
        {
          "contains": {
            "const": "snapshot_creation_on_read"
          }
        },
        {
          "contains": {
            "const": "patch_application"
          }
        },
        {
          "contains": {
            "const": "pull_request_mutation"
          }
        },
        {
          "contains": {
            "const": "shell_execution"
          }
        },
        {
          "contains": {
            "const": "merge_authorization"
          }
        }
      ],
      "description": "Operations forbidden while assembling this context pack."
    },
    "does_not_establish": {
      "type": "array",
      "minItems": 11,
      "maxItems": 11,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "actual_reading_proven",
          "answer_correct",
          "repo_understood",
          "all_relevant_context_used",
          "claims_true",
          "test_sufficiency",
          "regression_absence",
          "runtime_behavior",
          "forensic_ready",
          "merge_readiness",
          "security_correctness"
        ]
      },
      "allOf": [
        {
          "contains": {
            "const": "actual_reading_proven"
          }
        },
        {
          "contains": {
            "const": "answer_correct"
          }
        },
        {
          "contains": {
            "const": "repo_understood"
          }
        },
        {
          "contains": {
            "const": "all_relevant_context_used"
          }
        },
        {
          "contains": {
            "const": "claims_true"
          }
        },
        {
          "contains": {
            "const": "test_sufficiency"
          }
        },
        {
          "contains": {
            "const": "regression_absence"
          }
        },
        {
          "contains": {
            "const": "runtime_behavior"
          }
        },
        {
          "contains": {
            "const": "forensic_ready"
          }
        },
        {
          "contains": {
            "const": "merge_readiness"
          }
        },
        {
          "contains": {
            "const": "security_correctness"
          }
        }
      ],
      "description": "Boundaries this context pack does not establish."
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_context_tokens",
        "max_answer_tokens",
        "approx_context_chars_used",
        "truncated",
        "does_not_establish_quality"
      ],
      "properties": {
        "max_context_tokens": {
          "type": "integer",
          "minimum": 1
        },
        "max_answer_tokens": {
          "type": "integer",
          "minimum": 1
        },
        "approx_context_chars_used": {
          "type": "integer",
          "minimum": 0
        },
        "truncated": {
          "type": "boolean"
        },
        "does_not_establish_quality": {
          "type": "boolean",
          "const": true
        }
      },
      "description": "Token budget report. This is a constraint record, not a quality proof."
    }
  }
}
