{
  "$id": "https://heimgewebe.local/schema/repobrief-status-truth.v1.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "description": "Bounded governance projection that reconciles task control, roadmap semantics and selected claim-freshness coverage without becoming a second task authority or a product-readiness verdict.",
  "properties": {
    "$schema": {
      "const": "../../merger/lenskit/contracts/repobrief-status-truth.v1.schema.json"
    },
    "audit_package_coverage": {
      "const": "selected_remediation_packages"
    },
    "audit_packages": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "limitations": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          },
          "promotion": {
            "enum": [
              "not_applicable",
              "blocked",
              "deferred",
              "allowed"
            ]
          },
          "scope": {
            "minLength": 1,
            "type": "string"
          },
          "status": {
            "enum": [
              "open",
              "in_progress",
              "partial",
              "done"
            ]
          },
          "task_id": {
            "pattern": "^TASK-",
            "type": "string"
          },
          "verification": {
            "enum": [
              "not_started",
              "local_validated",
              "pr_verified",
              "main_verified",
              "runtime_verified"
            ]
          }
        },
        "required": [
          "task_id",
          "status",
          "scope",
          "verification",
          "promotion",
          "limitations"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "authority": {
      "const": "governance_projection"
    },
    "claim_freshness": {
      "additionalProperties": false,
      "properties": {
        "authority": {
          "const": "diagnostic_signal"
        },
        "coverage": {
          "const": "selected_declared_claims_only"
        },
        "does_not_prove": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "minItems": 3,
          "type": "array"
        },
        "green_means": {
          "minLength": 1,
          "type": "string"
        },
        "path": {
          "const": "docs/doc-freshness-registry.yml"
        },
        "tracked_claim_count": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "path",
        "authority",
        "coverage",
        "tracked_claim_count",
        "green_means",
        "does_not_prove"
      ],
      "type": "object"
    },
    "does_not_establish": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 5,
      "type": "array",
      "uniqueItems": true
    },
    "health_semantics": {
      "additionalProperties": false,
      "properties": {
        "forbidden_inferences": {
          "items": {
            "enum": [
              "product_ready",
              "release_ready",
              "review_complete",
              "test_complete",
              "semantic_truth",
              "runtime_correct"
            ]
          },
          "minItems": 4,
          "type": "array",
          "uniqueItems": true
        },
        "pass_means": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "pass_means",
        "forbidden_inferences"
      ],
      "type": "object"
    },
    "kind": {
      "const": "lenskit.repobrief_status_truth"
    },
    "observed_on": {
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "type": "string"
    },
    "open_followups": {
      "items": {
        "pattern": "^TASK-",
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "roadmap_surfaces": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "canonical_task_status": {
            "type": "boolean"
          },
          "checkbox_semantics": {
            "enum": [
              "item_local",
              "not_applicable"
            ]
          },
          "path": {
            "minLength": 1,
            "type": "string"
          },
          "phase_gate_independent": {
            "type": "boolean"
          },
          "required_markers": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "minItems": 2,
            "type": "array"
          },
          "role": {
            "enum": [
              "target_architecture",
              "ordered_roadmap",
              "operationalization_plan",
              "registration_index"
            ]
          }
        },
        "required": [
          "path",
          "role",
          "checkbox_semantics",
          "canonical_task_status",
          "phase_gate_independent",
          "required_markers"
        ],
        "type": "object"
      },
      "minItems": 3,
      "type": "array"
    },
    "scope": {
      "const": "repo_status_surfaces"
    },
    "source_of_truth": {
      "additionalProperties": false,
      "properties": {
        "board_projection": {
          "const": "docs/tasks/board.md"
        },
        "claim_freshness": {
          "const": "docs/doc-freshness-registry.yml"
        },
        "maturity_projection": {
          "const": "docs/status/repobrief-status-truth.v1.json"
        },
        "task_status": {
          "const": "docs/tasks/index.json"
        }
      },
      "required": [
        "task_status",
        "board_projection",
        "maturity_projection",
        "claim_freshness"
      ],
      "type": "object"
    },
    "status_semantics": {
      "additionalProperties": false,
      "properties": {
        "done": {
          "minLength": 1,
          "type": "string"
        },
        "done_does_not_imply": {
          "items": {
            "enum": [
              "phase_complete",
              "system_complete",
              "product_ready",
              "release_ready",
              "all_followups_closed"
            ]
          },
          "minItems": 4,
          "type": "array",
          "uniqueItems": true
        },
        "in_progress": {
          "minLength": 1,
          "type": "string"
        },
        "open": {
          "minLength": 1,
          "type": "string"
        },
        "partial": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "open",
        "in_progress",
        "partial",
        "done",
        "done_does_not_imply"
      ],
      "type": "object"
    },
    "system_maturity": {
      "additionalProperties": false,
      "properties": {
        "operational_readiness": {
          "enum": [
            "not_established",
            "partial",
            "bounded",
            "established"
          ]
        },
        "product_readiness": {
          "enum": [
            "not_established",
            "partial",
            "established"
          ]
        },
        "reasons": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "minItems": 1,
          "type": "array"
        },
        "release_readiness": {
          "enum": [
            "not_established",
            "blocked",
            "established"
          ]
        },
        "status": {
          "enum": [
            "mixed",
            "bounded_operational",
            "release_candidate",
            "released"
          ]
        }
      },
      "required": [
        "status",
        "product_readiness",
        "release_readiness",
        "operational_readiness",
        "reasons"
      ],
      "type": "object"
    },
    "task_summary": {
      "additionalProperties": false,
      "properties": {
        "by_status": {
          "additionalProperties": false,
          "properties": {
            "done": {
              "minimum": 0,
              "type": "integer"
            },
            "in_progress": {
              "minimum": 0,
              "type": "integer"
            },
            "open": {
              "minimum": 0,
              "type": "integer"
            },
            "partial": {
              "minimum": 0,
              "type": "integer"
            }
          },
          "required": [
            "open",
            "in_progress",
            "partial",
            "done"
          ],
          "type": "object"
        },
        "total": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "total",
        "by_status"
      ],
      "type": "object"
    },
    "version": {
      "const": "1.0"
    }
  },
  "required": [
    "kind",
    "version",
    "observed_on",
    "authority",
    "scope",
    "source_of_truth",
    "status_semantics",
    "task_summary",
    "system_maturity",
    "roadmap_surfaces",
    "claim_freshness",
    "audit_package_coverage",
    "audit_packages",
    "open_followups",
    "health_semantics",
    "does_not_establish"
  ],
  "title": "RepoBrief Status Truth v1",
  "type": "object"
}
