{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://heimgewebe.github.io/lenskit/contracts/architecture.source_roots.v1.schema.json",
  "title": "Lenskit Architecture Source Roots v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "version", "roots"],
  "properties": {
    "kind": {"const": "lenskit.architecture.source_roots"},
    "version": {"const": "1.0"},
    "roots": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "allOf": [
          {"not": {"pattern": "^/"}},
          {"not": {"pattern": "\\\\"}},
          {"not": {"pattern": "//"}},
          {"not": {"pattern": "(^|/)\\.{1,2}(/|$)"}},
          {"not": {"pattern": "/$"}}
        ]
      }
    }
  }
}
